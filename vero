<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#ffffff">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="ڤيرو">
    <title>ڤيرو - بيع واشتري كل شيء</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #FF6B6B; --primary-dark: #EE5A5A; --accent: #4ECDC4;
            --bg: #F7F7F7; --card: #FFFFFF; --text: #2D3436;
            --text-light: #636E72; --border: #E8E8E8;
            --green: #00B894; --red: #E74C3C; --orange: #F39C12;
            --blue: #3498DB; --purple: #9B59B6;
            --shadow: 0 2px 8px rgba(0,0,0,0.06);
            --shadow-lg: 0 4px 20px rgba(0,0,0,0.08);
            --radius: 16px; --radius-lg: 20px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
            background: var(--bg); color: var(--text); overflow-x: hidden; padding-bottom: 80px;
            -webkit-font-smoothing: antialiased;
        }
        .splash {
            position: fixed; inset: 0; background: white;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            z-index: 9999; transition: opacity 0.4s ease;
        }
        .splash.hidden { opacity: 0; pointer-events: none; }
        .splash-logo {
            width: 100px; height: 100px; background: var(--primary);
            border-radius: 28px; display: flex; align-items: center; justify-content: center;
            box-shadow: 0 8px 30px rgba(255,107,107,0.3);
            animation: bounce 1s ease infinite;
        }
        @keyframes bounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
        .splash-logo i { font-size: 45px; color: white; }
        .splash h1 { color: var(--text); margin-top: 20px; font-size: 32px; font-weight: 800; }
        .splash p { color: var(--text-light); margin-top: 8px; font-size: 15px; }
        .header {
            background: white; padding: 12px 16px;
            position: sticky; top: 0; z-index: 100;
            border-bottom: 1px solid var(--border);
        }
        .header-top { display: flex; align-items: center; justify-content: space-between; }
        .logo-text {
            font-size: 26px; font-weight: 800; color: var(--primary);
            display: flex; align-items: center; gap: 6px;
        }
        .logo-text i { font-size: 22px; }
        .header-actions { display: flex; gap: 8px; align-items: center; }
        .header-btn {
            background: var(--bg); border: none; color: var(--text);
            width: 42px; height: 42px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 18px; position: relative; transition: all 0.2s;
        }
        .header-btn:active { background: var(--border); transform: scale(0.95); }
        .badge {
            position: absolute; top: -2px; left: -2px;
            background: var(--primary); color: white; font-size: 10px;
            width: 18px; height: 18px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center; font-weight: bold;
        }
        .search-bar { padding: 8px 16px 12px; background: white; }
        .search-box {
            background: var(--bg); border-radius: 14px;
            display: flex; align-items: center; padding: 12px 16px; gap: 10px;
        }
        .search-box i { color: var(--text-light); font-size: 16px; }
        .search-box input {
            background: none; border: none; color: var(--text); flex: 1;
            font-size: 15px; outline: none;
        }
        .search-box input::placeholder { color: #B2BEC3; }
        .categories {
            padding: 8px 16px 4px; display: flex; gap: 10px;
            overflow-x: auto; scrollbar-width: none; background: white;
        }
        .categories::-webkit-scrollbar { display: none; }
        .cat-pill {
            padding: 8px 18px; border-radius: 20px; white-space: nowrap;
            cursor: pointer; font-size: 14px; font-weight: 500;
            transition: all 0.2s; border: 1.5px solid var(--border);
            background: white; color: var(--text);
        }
        .cat-pill.active { background: var(--primary); color: white; border-color: var(--primary); }
        .cat-pill:active { transform: scale(0.95); }
        .filters-row {
            display: flex; gap: 8px; padding: 8px 16px 12px;
            background: white; border-bottom: 1px solid var(--border);
            overflow-x: auto; scrollbar-width: none;
        }
        .filters-row::-webkit-scrollbar { display: none; }
        .filter-chip {
            padding: 6px 14px; border-radius: 18px; background: var(--bg); border: none;
            font-size: 13px; color: var(--text-light); cursor: pointer; white-space: nowrap;
            display: flex; align-items: center; gap: 4px;
        }
        .filter-chip i { font-size: 11px; }
        .products-feed {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; padding: 2px;
        }
        .product-card {
            background: var(--card); cursor: pointer; position: relative; overflow: hidden;
            transition: transform 0.2s;
        }
        .product-card:active { transform: scale(0.98); }
        .product-img-wrap {
            width: 100%; aspect-ratio: 3/4;
            background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
            position: relative; overflow: hidden;
        }
        .product-img-placeholder {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center; font-size: 60px;
        }
        .like-btn {
            position: absolute; top: 10px; left: 10px;
            width: 36px; height: 36px; border-radius: 50%;
            background: rgba(255,255,255,0.9); border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 16px; color: var(--text-light);
            transition: all 0.2s; backdrop-filter: blur(4px);
        }
        .like-btn.liked { color: var(--primary); }
        .like-btn:active { transform: scale(0.9); }
        .size-badge {
            position: absolute; bottom: 10px; right: 10px;
            background: rgba(0,0,0,0.6); color: white;
            padding: 4px 10px; border-radius: 8px;
            font-size: 12px; font-weight: 600; backdrop-filter: blur(4px);
        }
        .product-info { padding: 10px 12px 14px; }
        .product-price { font-size: 17px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
        .product-name { font-size: 13px; color: var(--text-light); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .product-meta { display: flex; align-items: center; gap: 6px; margin-top: 6px; font-size: 12px; color: #B2BEC3; }
        .seller-avatar {
            width: 20px; height: 20px; border-radius: 50%;
            background: var(--primary); color: white;
            display: flex; align-items: center; justify-content: center;
            font-size: 10px; font-weight: bold;
        }
        .product-detail {
            position: fixed; inset: 0; background: white; z-index: 200;
            display: none; flex-direction: column; overflow-y: auto;
            animation: slideUp 0.3s ease;
        }
        .product-detail.active { display: flex; }
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .detail-gallery { position: relative; width: 100%; aspect-ratio: 1; background: var(--bg); }
        .detail-gallery .placeholder-img {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center; font-size: 120px;
        }
        .detail-close {
            position: absolute; top: 16px; right: 16px;
            width: 40px; height: 40px; border-radius: 50%;
            background: rgba(255,255,255,0.9); border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 18px; backdrop-filter: blur(4px); box-shadow: var(--shadow);
        }
        .detail-like {
            position: absolute; top: 16px; left: 16px;
            width: 40px; height: 40px; border-radius: 50%;
            background: rgba(255,255,255,0.9); border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 18px; color: var(--text-light);
            backdrop-filter: blur(4px); box-shadow: var(--shadow);
        }
        .detail-like.liked { color: var(--primary); }
        .detail-dots {
            position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
            display: flex; gap: 6px;
        }
        .dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.5); }
        .dot.active { background: white; }
        .detail-body { padding: 20px; flex: 1; }
        .detail-price { font-size: 28px; font-weight: 800; color: var(--text); }
        .detail-name { font-size: 18px; font-weight: 600; margin-top: 4px; color: var(--text); }
        .detail-meta { 
            display: flex; align-items: center; gap: 8px;
            margin-top: 12px; padding-bottom: 16px; border-bottom: 1px solid var(--border);
        }
        .detail-seller {
            display: flex; align-items: center; gap: 10px;
            padding: 16px 0; border-bottom: 1px solid var(--border);
        }
        .detail-seller-avatar {
            width: 48px; height: 48px; border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white; display: flex; align-items: center; justify-content: center;
            font-size: 20px; font-weight: bold;
        }
        .detail-seller-info { flex: 1; }
        .detail-seller-name { font-weight: 600; font-size: 15px; }
        .detail-seller-rating { 
            display: flex; align-items: center; gap: 4px;
            font-size: 13px; color: var(--text-light); margin-top: 2px;
        }
        .stars { color: #FDCB6E; }
        .detail-seller-btn {
            padding: 8px 16px; border-radius: 20px;
            border: 1.5px solid var(--primary); background: none;
            color: var(--primary); font-weight: 600; font-size: 13px; cursor: pointer;
        }
        .detail-seller-btn:active { background: rgba(255,107,107,0.1); }
        .detail-section { padding: 16px 0; border-bottom: 1px solid var(--border); }
        .detail-section-title { font-size: 15px; font-weight: 700; margin-bottom: 10px; color: var(--text); }
        .detail-section-text { font-size: 14px; color: var(--text-light); line-height: 1.7; }
        .detail-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
        .detail-tag {
            padding: 6px 14px; border-radius: 16px;
            background: var(--bg); font-size: 13px; color: var(--text-light);
        }
        .detail-actions {
            position: sticky; bottom: 0; background: white;
            padding: 16px; border-top: 1px solid var(--border);
            display: flex; gap: 12px;
        }
        .btn-primary {
            flex: 1; background: var(--primary); color: white;
            border: none; padding: 16px; border-radius: 14px;
            font-size: 16px; font-weight: 700; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: all 0.2s;
        }
        .btn-primary:active { transform: scale(0.98); background: var(--primary-dark); }
        .btn-secondary {
            width: 56px; height: 56px; border-radius: 14px;
            border: 2px solid var(--border); background: white;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 20px; color: var(--text);
        }
        .btn-secondary:active { background: var(--bg); }
        .btn-danger {
            flex: 1; background: var(--red); color: white;
            border: none; padding: 16px; border-radius: 14px;
            font-size: 16px; font-weight: 700; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-danger:active { opacity: 0.9; }
        .chat-screen {
            position: fixed; inset: 0; background: white; z-index: 300;
            display: none; flex-direction: column;
        }
        .chat-screen.active { display: flex; }
        .chat-header {
            padding: 12px 16px; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 12px;
        }
        .chat-back {
            width: 36px; height: 36px; border-radius: 50%;
            border: none; background: var(--bg); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
        }
        .chat-user { display: flex; align-items: center; gap: 10px; flex: 1; }
        .chat-user-avatar {
            width: 40px; height: 40px; border-radius: 50%;
            background: var(--primary); color: white;
            display: flex; align-items: center; justify-content: center; font-weight: bold;
        }
        .chat-user-name { font-weight: 600; font-size: 15px; }
        .chat-user-status { font-size: 12px; color: var(--green); }
        .chat-messages {
            flex: 1; overflow-y: auto; padding: 16px;
            display: flex; flex-direction: column; gap: 12px;
        }
        .message {
            max-width: 75%; padding: 12px 16px;
            border-radius: 18px; font-size: 14px; line-height: 1.5;
        }
        .message.sent {
            align-self: flex-start; background: var(--primary); color: white;
            border-bottom-right-radius: 4px;
        }
        .message.received {
            align-self: flex-end; background: var(--bg); color: var(--text);
            border-bottom-left-radius: 4px;
        }
        .message-time { font-size: 10px; opacity: 0.7; margin-top: 4px; }
        .chat-input-area {
            padding: 12px 16px; border-top: 1px solid var(--border);
            display: flex; gap: 10px; align-items: center;
        }
        .chat-input {
            flex: 1; padding: 12px 16px; border-radius: 24px;
            border: 1.5px solid var(--border); background: var(--bg);
            font-size: 15px; outline: none; font-family: inherit;
        }
        .chat-input:focus { border-color: var(--primary); }
        .chat-send {
            width: 44px; height: 44px; border-radius: 50%;
            background: var(--primary); color: white; border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 18px;
        }
        .chat-send:active { transform: scale(0.95); }
        .sell-modal .modal-sheet { padding: 24px; }
        .sell-modal h2 { margin-bottom: 20px; font-size: 22px; }
        .image-upload {
            width: 100%; aspect-ratio: 1; border: 2px dashed var(--border);
            border-radius: var(--radius); display: flex;
            flex-direction: column; align-items: center; justify-content: center;
            gap: 10px; color: var(--text-light); cursor: pointer;
            margin-bottom: 16px; transition: all 0.2s;
        }
        .image-upload:active { border-color: var(--primary); background: rgba(255,107,107,0.05); }
        .image-upload i { font-size: 40px; }
        .form-group { margin-bottom: 16px; }
        .form-group label {
            display: block; margin-bottom: 6px; font-size: 14px;
            font-weight: 600; color: var(--text);
        }
        .form-group input, .form-group textarea, .form-group select {
            width: 100%; padding: 14px; border: 1.5px solid var(--border);
            border-radius: 12px; font-size: 15px; outline: none;
            transition: border-color 0.2s; font-family: inherit; background: white;
        }
        .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
            border-color: var(--primary);
        }
        .form-group textarea { min-height: 100px; resize: vertical; }
        .modal-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.4);
            z-index: 200; display: none; align-items: flex-end;
            justify-content: center; backdrop-filter: blur(4px);
        }
        .modal-overlay.active { display: flex; }
        .modal-sheet {
            background: white; width: 100%; max-width: 500px;
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            max-height: 90vh; overflow-y: auto;
            animation: slideUpSheet 0.3s ease;
        }
        @keyframes slideUpSheet { from { transform: translateY(100%); } }
        .cart-drawer {
            position: fixed; inset: 0; z-index: 300; display: none;
        }
        .cart-drawer.active { display: block; }
        .cart-backdrop {
            position: absolute; inset: 0; background: rgba(0,0,0,0.4);
            backdrop-filter: blur(4px);
        }
        .cart-panel {
            position: absolute; left: 0; top: 0; bottom: 0;
            width: 85%; max-width: 380px; background: white;
            box-shadow: var(--shadow-lg); display: flex; flex-direction: column;
            animation: slideInCart 0.3s ease;
        }
        @keyframes slideInCart { from { transform: translateX(-100%); } }
        .cart-header {
            padding: 20px; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
        }
        .cart-items { flex: 1; overflow-y: auto; padding: 16px; }
        .cart-item {
            display: flex; gap: 12px; padding: 12px;
            background: var(--bg); border-radius: var(--radius);
            margin-bottom: 10px;
        }
        .cart-item-img {
            width: 70px; height: 70px; border-radius: 10px;
            background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
            display: flex; align-items: center; justify-content: center;
            font-size: 30px; flex-shrink: 0;
        }
        .cart-item-info { flex: 1; }
        .cart-item-name { font-size: 14px; font-weight: 600; }
        .cart-item-price { color: var(--primary); font-weight: 700; font-size: 14px; }
        .cart-item-remove {
            background: none; border: none; color: var(--primary);
            cursor: pointer; font-size: 16px;
        }
        .cart-footer {
            padding: 20px; border-top: 1px solid var(--border);
        }
        .cart-total-row {
            display: flex; justify-content: space-between;
            margin-bottom: 16px; font-size: 18px; font-weight: 700;
        }
        .empty-state {
            text-align: center; padding: 60px 20px; color: var(--text-light);
        }
        .empty-state i { font-size: 56px; margin-bottom: 16px; display: block; color: var(--border); }
        .empty-state h3 { color: var(--text); margin-bottom: 8px; }
        .profile-header {
            background: white; padding: 30px 20px;
            text-align: center; border-bottom: 1px solid var(--border);
        }
        .profile-avatar-large {
            width: 90px; height: 90px; border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white; margin: 0 auto 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 36px; font-weight: bold;
            box-shadow: 0 4px 15px rgba(255,107,107,0.3);
        }
        .profile-name { font-size: 20px; font-weight: 700; }
        .profile-username { color: var(--text-light); font-size: 14px; margin-top: 4px; }
        .profile-stats {
            display: flex; justify-content: center; gap: 30px; margin-top: 20px;
        }
        .stat { text-align: center; }
        .stat-value { font-size: 20px; font-weight: 700; color: var(--text); }
        .stat-label { font-size: 12px; color: var(--text-light); margin-top: 2px; }
        .profile-menu { padding: 8px 16px; }
        .menu-item {
            display: flex; align-items: center; gap: 14px;
            padding: 16px; background: white; border-radius: var(--radius);
            margin-bottom: 8px; cursor: pointer; transition: all 0.2s;
            border: 1px solid var(--border);
        }
        .menu-item:active { background: var(--bg); }
        .menu-item i { font-size: 20px; color: var(--primary); width: 24px; text-align: center; }
        .menu-item span { flex: 1; font-weight: 500; font-size: 15px; }
        .menu-item .arrow { color: #B2BEC3; font-size: 14px; }

        /* Admin Styles */
        .admin-login-screen {
            position: fixed; inset: 0; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            z-index: 600; display: none; flex-direction: column;
            align-items: center; justify-content: center; padding: 40px 30px;
        }
        .admin-login-screen.active { display: flex; }
        .admin-login-card {
            background: white; border-radius: var(--radius-lg);
            padding: 40px 30px; width: 100%; max-width: 400px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: slideUpSheet 0.4s ease;
        }
        .admin-login-card h2 {
            text-align: center; margin-bottom: 8px; font-size: 24px;
        }
        .admin-login-card p {
            text-align: center; color: var(--text-light); margin-bottom: 30px; font-size: 14px;
        }
        .admin-login-card .logo-text { justify-content: center; margin-bottom: 30px; font-size: 32px; }
        .admin-input {
            width: 100%; padding: 16px; border: 2px solid var(--border);
            border-radius: 12px; font-size: 16px; margin-bottom: 16px;
            outline: none; transition: border-color 0.2s; font-family: inherit;
        }
        .admin-input:focus { border-color: var(--primary); }
        .admin-btn {
            width: 100%; padding: 16px; background: var(--primary); color: white;
            border: none; border-radius: 12px; font-size: 16px; font-weight: 700;
            cursor: pointer; transition: all 0.2s;
        }
        .admin-btn:active { transform: scale(0.98); background: var(--primary-dark); }
        .admin-error {
            color: var(--red); font-size: 13px; text-align: center;
            margin-top: 12px; display: none;
        }
        .admin-error.show { display: block; }
        .admin-back {
            background: none; border: none; color: white;
            margin-top: 20px; font-size: 14px; cursor: pointer;
            display: flex; align-items: center; gap: 6px;
        }
        .admin-dashboard {
            position: fixed; inset: 0; background: #f0f2f5; z-index: 500;
            display: none; flex-direction: column; overflow-y: auto;
        }
        .admin-dashboard.active { display: flex; }
        .admin-header {
            background: white; padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 10;
        }
        .admin-header h1 { font-size: 20px; display: flex; align-items: center; gap: 8px; }
        .admin-header h1 i { color: var(--primary); }
        .admin-logout {
            background: var(--red); color: white; border: none;
            padding: 8px 16px; border-radius: 8px; font-size: 13px;
            cursor: pointer; font-weight: 600;
        }
        .admin-stats-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 12px; padding: 16px;
        }
        .admin-stat-card {
            background: white; border-radius: var(--radius);
            padding: 20px; box-shadow: var(--shadow);
        }
        .admin-stat-card .icon {
            width: 44px; height: 44px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 20px; margin-bottom: 12px;
        }
        .admin-stat-card .icon.blue { background: #EBF5FB; color: var(--blue); }
        .admin-stat-card .icon.green { background: #EAFAF1; color: var(--green); }
        .admin-stat-card .icon.orange { background: #FEF5E7; color: var(--orange); }
