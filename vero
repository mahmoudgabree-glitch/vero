        if (product) {
            product.name = name;
            product.price = price;
            product.oldPrice = oldPrice;
            product.category = category;
            product.size = size;
            product.condition = condition;
            product.desc = desc;
            showToast('تم تحديث المنتج بنجاح');
        }
    } else {
        // Add new
        const newProduct = {
            id: Date.now(),
            name: name,
            price: price,
            oldPrice: oldPrice,
            category: category,
            size: size,
            condition: condition,
            seller: "أدمن",
            emoji: "📦",
            desc: desc || "منتج جديد"
        };
        products.unshift(newProduct);
        showToast('تم إضافة المنتج بنجاح');
    }

    saveProducts();
    closeEditModal();
    renderAdminProducts();
    renderProducts(products);
    updateAdminStats();
}

function deleteProductFromEdit() {
    const id = document.getElementById('editProductId').value;
    if (id) {
        adminDeleteProduct(parseInt(id));
        closeEditModal();
    }
}

function adminDeleteProduct(id) {
    if (!confirm('هل أنت متأكد من حذف هذا المنتج؟')) return;
    products = products.filter(p => p.id !== id);
    saveProducts();
    renderAdminProducts();
    renderProducts(products);
    updateAdminStats();
    showToast('تم حذف المنتج');
}

function closeEditModal() {
    document.getElementById('editProductModal').classList.remove('active');
}

function renderAdminOrders() {
    const container = document.getElementById('adminOrdersTable');
    const allOrders = [...orders, ...cart.map((item, i) => ({
        id: 'CART-' + i,
        items: [item],
        total: item.price,
        name: 'زائر',
        phone: '-',
        address: '-',
        date: new Date().toLocaleDateString('ar-SA'),
        status: 'pending'
    }))];

    if (allOrders.length === 0) {
        container.innerHTML = '<div class="admin-empty"><i class="fas fa-shopping-bag"></i><p>لا توجد طلبات</p></div>';
        return;
    }

    container.innerHTML = `
        <table class="admin-table">
            <thead>
                <tr>
                    <th>رقم الطلب</th>
                    <th>المنتجات</th>
                    <th>المجموع</th>
                    <th>التاريخ</th>
                    <th>الحالة</th>
                </tr>
            </thead>
            <tbody>
                ${allOrders.map(o => `
                    <tr>
                        <td><strong>#${o.id}</strong></td>
                        <td>${o.items.length} منتج</td>
                        <td>${o.total} ر.س</td>
                        <td>${o.date}</td>
                        <td><span class="admin-badge ${o.status === 'pending' ? 'badge-yellow' : o.status === 'confirmed' ? 'badge-green' : 'badge-blue'}">${o.status === 'pending' ? 'قيد المراجعة' : o.status === 'confirmed' ? 'تم التأكيد' : 'تم التوصيل'}</span></td>
                    </tr>
                `).join('')}
            </tbody>
        </table>
    `;
}

function renderAdminUsers() {
    const container = document.getElementById('adminUsersTable');
    const uniqueSellers = [...new Set(products.map(p => p.seller))];

    if (uniqueSellers.length === 0) {
        container.innerHTML = '<div class="admin-empty"><i class="fas fa-users"></i><p>لا يوجد مستخدمين</p></div>';
        return;
    }

    container.innerHTML = `
        <table class="admin-table">
            <thead>
                <tr>
                    <th>المستخدم</th>
                    <th>الإعلانات</th>
                    <th>إجمالي المبيعات</th>
                    <th>التقييم</th>
                </tr>
            </thead>
            <tbody>
                ${uniqueSellers.map(seller => {
                    const sellerProducts = products.filter(p => p.seller === seller);
                    const totalSales = sellerProducts.reduce((sum, p) => sum + p.price, 0);
                    return `
                        <tr>
                            <td><strong>${seller}</strong></td>
                            <td>${sellerProducts.length}</td>
                            <td>${totalSales} ر.س</td>
                            <td><span class="admin-badge badge-green">4.5 <i class="fas fa-star" style="font-size:10px"></i></span></td>
                        </tr>
                    `;
                }).join('')}
            </tbody>
        </table>
    `;
}

function updateAdminAnalytics() {
    const categories = {};
    products.forEach(p => {
        categories[p.category] = (categories[p.category] || 0) + 1;
    });
    const topCat = Object.entries(categories).sort((a, b) => b[1] - a[1])[0];
    document.getElementById('topCategory').textContent = topCat ? getCategoryName(topCat[0]) : '-';

    const avg = products.length > 0 ? Math.round(products.reduce((sum, p) => sum + p.price, 0) / products.length) : 0;
    document.getElementById('avgPrice').textContent = avg + ' ر.س';

    const revenue = products.reduce((sum, p) => sum + p.price, 0);
    document.getElementById('totalRevenue').textContent = revenue + ' ر.س';
}

// ==================== STORAGE ====================
function saveProducts() { localStorage.setItem('vero_products', JSON.stringify(products)); }
function loadProducts() { 
    const saved = localStorage.getItem('vero_products'); 
    if (saved) products = JSON.parse(saved);
}
function saveCart() { localStorage.setItem('vero_cart', JSON.stringify(cart)); }
function loadCart() { 
    const saved = localStorage.getItem('vero_cart'); 
    if (saved) { cart = JSON.parse(saved); updateCartBadge(); }
}
function saveLikes() { localStorage.setItem('vero_likes', JSON.stringify([...likedProducts])); }
function loadLikes() { 
    const saved = localStorage.getItem('vero_likes'); 
    if (saved) likedProducts = new Set(JSON.parse(saved));
}
function saveListings() { localStorage.setItem('vero_listings', JSON.stringify(userListings)); }
function loadListings() { 
    const saved = localStorage.getItem('vero_listings'); 
    if (saved) { 
        userListings = JSON.parse(saved); 
        products = [...userListings, ...products.filter(p => !userListings.find(u => u.id === p.id))];
    }
}
function saveOrders() { localStorage.setItem('vero_orders', JSON.stringify(orders)); }
function loadOrders() { 
    const saved = localStorage.getItem('vero_orders'); 
    if (saved) orders = JSON.parse(saved);
}

// ==================== UTILS ====================
function showToast(msg) {
    const toast = document.getElementById('toast');
    document.getElementById('toastMsg').textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
}

function closeModal(e) {
    if (e.target.classList.contains('modal-overlay')) {
        e.target.classList.remove('active');
        document.body.style.overflow = '';
    }
}

let startY = 0;
document.addEventListener('touchstart', e => { startY = e.touches[0].pageY; });
document.addEventListener('touchmove', e => {
    const y = e.touches[0].pageY;
    if (document.scrollingElement.scrollTop === 0 && y > startY) {
        e.preventDefault();
    }
}, { passive: false });
</script>

